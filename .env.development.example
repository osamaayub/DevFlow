# Development environment — loaded by `next dev`.
# Copy to `.env.development.local` and fill in real values (that file is gitignored).

# Local MongoDB (or a dev Atlas cluster)
MONGODB_URI=mongodb://localhost:27017/devflow

# NextAuth secret — generate with: npx auth secret
AUTH_SECRET=

# GitHub OAuth (dev app — callback http://localhost:3000/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (dev app — callback http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Verbose logs in development
LOG_LEVEL=debug
