# MongoDB connection string (required at build and runtime)
MONGODB_URI=

# NextAuth secret — generate with: npx auth secret
AUTH_SECRET=

# GitHub OAuth (optional — required for GitHub login)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (optional — required for Google login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Pino log level: debug | info | warn | error (optional)
LOG_LEVEL=
