# Production environment — loaded by `next build` / `next start`.
# Copy to `.env.production.local` and fill in real values (that file is gitignored).
# In CI/CD these come from the `production` GitHub Environment secrets instead.

# Production MongoDB (e.g. MongoDB Atlas)
MONGODB_URI=

# NextAuth secret — generate with: npx auth secret
AUTH_SECRET=

# GitHub OAuth (prod app — callback https://<your-domain>/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (prod app — callback https://<your-domain>/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Less verbose logs in production
LOG_LEVEL=info
